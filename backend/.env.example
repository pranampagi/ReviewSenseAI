# App
APP_NAME=ReviewSense AI
APP_ENV=development
SECRET_KEY=your-32-char-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# SQL Database
# Development (SQLite — no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./reviewsense.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/reviewsense

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=reviewsense

# ML
HF_MODEL_ID=distilbert-base-uncased-finetuned-sst-2-english
ML_MODELS_DIR=./ml/models
ASPECT_MODEL_VOCAB_SIZE=10000
ASPECT_MODEL_EMBED_DIM=128
ASPECT_MODEL_HIDDEN=256

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app
